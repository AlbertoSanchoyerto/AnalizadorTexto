# Información del proyecto
PROJECT_NAME           = "AnalizadorTexto"
PROJECT_BRIEF          = "Documentación del Analizador de Texto"

# Entrada
INPUT                  = src include .
FILE_PATTERNS          = *.cpp *.h *.md LICENSE
RECURSIVE              = YES

MARKDOWN_SUPPORT       = YES
USE_MDFILE_AS_MAINPAGE = README.md

# Salida
OUTPUT_DIRECTORY       = docs
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
OUTPUT_LANGUAGE        = Spanish

GENERATE_RTF           = YES
RTF_HYPERLINKS         = YES
RTF_OUTPUT             = rtf

# Extracción
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO

# C++ settings
OPTIMIZE_OUTPUT_FOR_C  = YES
OPTIMIZE_OUTPUT_JAVA   = NO
OPTIMIZE_FOR_FORTRAN   = NO

# Mostrar código fuente
SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES

# Diagramas (opcional)
HAVE_DOT               = NO

# Avisos
WARNINGS               = YES
QUIET                  = NO

# Preprocesador
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO

# Configuración de extensión
EXTENSION_MAPPING      = hpp=C++